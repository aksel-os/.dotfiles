{ lib, inputs, withSystem, ... }:

let
  inherit
    (lib)
    recursiveUpdate
    concatLists
    singleton # Create single element list
    mkDefault # Set low prio in case of overriding
    optionals # Return list if true
  ;
    
  mkSystem = {
    self,
      name,
      os,
      system,
      nixpkgs,
      nix-darwin,
      modules ? [ ],
      specialArgs ? { },
    ...
  }:
    let
      libSystem = if os == "darwin" then nix-darwin.lib.darwinSystem else nixpkgs.lib.nixosSystem;
    in
      libSystem {
        specialArgs = recursiveUpdate {
          inherit inputs;
          
        } specialArgs; # Append additional args
        
        modules = concatLists [
          # Hosts have a defined path
          "$(self)/hosts/$(name)"

          # _module.args.pkgs is defined perSystem in flake-parts/system.nix
          (singleton {
            _module.args = withSystem system (
            { self', inputs', ... }:
            {
              inherit self' inputs';
            }
            );
          })

          # Base reqs
          (singleton {
            networking.hostName = mkDefault name; 

            nixpkgs.hostPlatform = mkDefault system;
          })

          # Only used by NixOS
          (optionals (os != "darwin") (singleton {
            flake.source = nixpkgs.outPath;
          }))
          
          # Only used by Darwin
          (optionals (os == "darwin") (singleton {
            nixpkgs.source = mkDefault nixpkgs;

            system = {
              checks.verifyNixPath = false;

              darwinVersionSuffix = ".${inputs.darwin.shortRev or inputs.darwin.dirtyShortRev or "dirty"}";
              darwinRevision = inputs.darwin.rev or inputs.darwin.dirtyRev or "dirty";              
            };
          }))

          # Append extra modules
          modules
        ];
      };

  mkConfiguration = {
    name,
    os,
    libSystem,
    ...
  }:
    if (os == "darwin") then
      { darwinConfigurations.${name} = libSystem; }
    else
      { nixosConfigurations.${name} = libSystem; };

  mkHost = {
    name,
    os,
    system,
    nixpkgs,
    nix-darwin,
    modules,
    specialArgs,
    ...
  }:
    {
      mkConfiguration = {
        inherit name os;

        libSystem = mkSystem {
          inherit name os system nixpkgs nix-darwin modules specialArgs;
        };
      };
    };
  
in {
  inherit
    mkHost;
}

